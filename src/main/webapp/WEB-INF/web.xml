<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>Lycee Management System</display-name>

    <!-- Servlets -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.lycee.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.lycee.servlet.DashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EleveServlet</servlet-name>
        <servlet-class>com.lycee.servlet.EleveServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ClasseServlet</servlet-name>
        <servlet-class>com.lycee.servlet.ClasseServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>NoteServlet</servlet-name>
        <servlet-class>com.lycee.servlet.NoteServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AbsenceServlet</servlet-name>
        <servlet-class>com.lycee.servlet.AbsenceServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>PdfServlet</servlet-name>
        <servlet-class>com.lycee.servlet.PdfServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DocumentsServlet</servlet-name>
        <servlet-class>com.lycee.servlet.DocumentsServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ExcelServlet</servlet-name>
        <servlet-class>com.lycee.servlet.ExcelServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UtilisateurServlet</servlet-name>
        <servlet-class>com.lycee.servlet.UtilisateurServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ParametreServlet</servlet-name>
        <servlet-class>com.lycee.servlet.ParametreServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>PhotoServlet</servlet-name>
        <servlet-class>com.lycee.servlet.PhotoServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>NotificationServlet</servlet-name>
        <servlet-class>com.lycee.servlet.NotificationServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AssetServlet</servlet-name>
        <servlet-class>com.lycee.servlet.AssetServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ChartDataServlet</servlet-name>
        <servlet-class>com.lycee.servlet.ChartDataServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SallesApiServlet</servlet-name>
        <servlet-class>com.lycee.servlet.SallesApiServlet</servlet-class>
    </servlet>

    <!-- Mappings -->
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/mot-de-passe-oublie</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/app/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EleveServlet</servlet-name>
        <url-pattern>/app/eleves/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ClasseServlet</servlet-name>
        <url-pattern>/app/classes/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>NoteServlet</servlet-name>
        <url-pattern>/app/notes/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AbsenceServlet</servlet-name>
        <url-pattern>/app/absences/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PdfServlet</servlet-name>
        <url-pattern>/app/pdf/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DocumentsServlet</servlet-name>
        <url-pattern>/app/documents</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ExcelServlet</servlet-name>
        <url-pattern>/app/excel/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UtilisateurServlet</servlet-name>
        <url-pattern>/app/utilisateurs/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ParametreServlet</servlet-name>
        <url-pattern>/app/parametres/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PhotoServlet</servlet-name>
        <url-pattern>/app/photos/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>NotificationServlet</servlet-name>
        <url-pattern>/app/notifications</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AssetServlet</servlet-name>
        <url-pattern>/assets/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ChartDataServlet</servlet-name>
        <url-pattern>/api/charts/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SallesApiServlet</servlet-name>
        <url-pattern>/api/salles</url-pattern>
    </servlet-mapping>

    <!-- Error Pages -->
    <error-page>
        <error-code>400</error-code>
        <location>/WEB-INF/vues/erreur/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/vues/erreur/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>403</error-code>
        <location>/WEB-INF/vues/erreur/403.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/vues/erreur/500.jsp</location>
    </error-page>
    <error-page>
        <exception-type>java.lang.Throwable</exception-type>
        <location>/WEB-INF/vues/erreur/500.jsp</location>
    </error-page>
</web-app>
